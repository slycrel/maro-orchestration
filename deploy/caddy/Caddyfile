# Caddy reverse proxy for the maro box — public entry at maro.feifdom.com.
# Source of truth: deploy/caddy/Caddyfile in the maro-orchestration repo
# (same convention as deploy/hermes/*); install with:
#   sudo cp deploy/caddy/Caddyfile /etc/caddy/Caddyfile && sudo systemctl reload caddy
#
# NOTE: this is the LOCAL-LOGIN-ONLY baseline / fallback. The live config
# since 2026-07-17 is Caddyfile.github-oauth (same shape + GitHub OAuth);
# keep the two in sync when editing routes.
#
# Auth posture (Jeremy 2026-07-17): SSO as the floor, implementation
# swappable. caddy-security provides the auth portal + JWT authorization;
# the identity provider behind the portal starts as a local user store and
# upgrades to GitHub OAuth by adding a provider block (see
# deploy/caddy/README.md) — the routes' authorization policy does not
# change when the provider does.
#
# Serving shape (2026-07-17, Jeremy): dedicated subdomain
# maro.feifdom.com with the viz server at the ROOT (no /maro prefix).
#
# Secrets: JWT_SHARED_KEY lives in /etc/caddy/caddy.env (mode 600, not in
# git). The local user db is /etc/caddy/auth/users.json (not in git).

{
	order authenticate before respond
	order authorize before basic_auth

	security {
		local identity store localdb {
			realm local
			path /etc/caddy/auth/users.json
		}

		authentication portal maro_portal {
			crypto default token lifetime 86400
			crypto key sign-verify from env JWT_SHARED_KEY
			enable identity store localdb
			cookie domain maro.feifdom.com
			ui {
				links {
					"Maro visualizations" /index.html icon "las la-chart-bar"
				}
			}
			# No settings link: this plugin build 404s /auth/settings (the
			# portal refactor dropped the self-service pages). Password
			# changes happen via the hash-reset procedure in the README.
			transform user {
				match origin local
				action add role authp/user
			}
		}

		authorization policy maro_policy {
			set auth url https://maro.feifdom.com/auth/
			crypto key verify from env JWT_SHARED_KEY
			allow roles authp/admin authp/user
		}
	}
}

maro.feifdom.com {
	route /auth* {
		authenticate with maro_portal
	}

	# Bare / lands on the viz root, which its allowlist denies (blank
	# 403) — send it to the index the allowlist does serve. Unauthed
	# hits on /index.html bounce to the portal via the policy's auth url.
	redir / /index.html

	# /auth* sorts ahead of /* (Caddy orders same-directive routes by
	# matcher specificity), so this catch-all never shadows the portal.
	route /* {
		authorize with maro_policy
		reverse_proxy 127.0.0.1:8787
	}
}

# Local wiring check (no TLS, no cookies across domains — proves the
# portal renders and unauthenticated / redirects; full flow needs the
# real domain): curl -s http://127.0.0.1:8880/auth | head
http://127.0.0.1:8880 {
	route /auth* {
		authenticate with maro_portal
	}

	redir / /index.html

	route /* {
		authorize with maro_policy
		reverse_proxy 127.0.0.1:8787
	}
}
