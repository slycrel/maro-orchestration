[run]
source = src
omit =
    src/poe_orchestration.egg-info/*
    */test_*
    */tests/*

[report]
# Session 20 adversarial review finding 3.7: coverage was unmeasured. Current
# 2026-07-14 full-suite baseline with these omits is 78.04%. Keep the 70% floor
# as a conservative ratchet while the flat-module refactor is still active;
# tighten over time, and fail CI if coverage drops below this.
fail_under = 70
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if TYPE_CHECKING:
    except ImportError:
    pass  # pragma: no cover

[html]
directory = output/coverage_html
